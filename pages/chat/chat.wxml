<!-- pages/chat/chat.wxml -->
<view class="page-container">

<!-- 1. 顶部导航栏 (完全复用日记页结构) -->
<view class="custom-nav" style="padding-top: {{statusBarHeight}}px;">
  <view class="nav-left" bindtap="goBack">
    <van-icon name="arrow-left" size="22px" color="#3a3a3a" />
  </view>
  <!-- 标题强制隶书 -->
  <view class="nav-center">
      <image class="header-avatar" src="/images/spirit-icon.png" mode="aspectFit" />
      <text class="font-lishu">器灵</text>
    </view>
  <view class="nav-right"></view>
</view>

<!-- 2. 中间内容区 (Flex: 1 自适应高度) -->
<view class="main-content">
  <scroll-view 
    class="chat-scroll" 
    scroll-y 
    scroll-into-view="{{scrollToViewId}}"
    scroll-with-animation="{{true}}"
    bindscrolltoupper="onScrollToUpper"
    bindtap="hideKeyboard"
  >
    <view class="padding-top"></view>

    <block wx:for="{{msgList}}" wx:key="id">
      <!-- 时间戳 -->
      <view class="time-stamp" wx:if="{{item.showTime}}">{{item.timeStr}}</view>

      <!-- 加载历史消息提示 -->
      <view class="loading-history" wx:if="{{index === 0 && hasMoreHistory}}">
        <text wx:if="{{isLoadingHistory}}">加载中...</text>
        <text wx:else>上拉加载更多</text>
      </view>

      <!-- 消息行 -->
      <view class="msg-row {{item.role === 'user' ? 'row-user' : 'row-ai'}}" id="msg-{{index}}">
        <!-- 气泡 (内容强制系统字体) -->
        <view class="bubble font-system">
          <text user-select>{{item.content}}</text>
          <view wx:if="{{item.isLoading}}" class="loading-dots">...</view>
          <view class="daily-task-buttons" wx:if="{{item.showDailyTaskButtons && !item.isLoading}}">
            <view class="task-btn primary" bindtap="onGoPractice" data-gongfaid="{{item.gongfaId}}" data-gongfaname="{{item.gongfaName}}">去修炼</view>
          </view>
        </view>
      </view>
    </block>

    <!-- 底部锚点 -->
    <view id="bottom-anchor" style="height: 20rpx;"></view>
  </scroll-view>
  
  <!-- 今日宜练和心魔修炼按钮 -->
  <view class="daily-task-fixed">
    <view class="daily-task-btn" bindtap="onDailyTaskTap">今日宜练</view>
    <view class="daily-task-btn" bindtap="onHeartDemonTap" wx:if="{{!isHeartDemonMode}}">心魔修炼</view>
    <view class="daily-task-btn complete-btn" bindtap="onCompleteDemonTap" wx:else>完成修炼</view>
  </view>
</view>

<!-- 心魔修炼类型选择弹窗 -->
<view class="demon-popup-mask" wx:if="{{showDemonTypePopup}}" bindtap="onCloseDemonPopup">
  <view class="dialog-container" catchtap="preventTouchMove">
    <image class="dialog-bg" src="/images/dialog-bg.png" mode="stretchFix" />
    <view class="dialog-content">
      <view class="demon-popup-title">选择修炼的心魔</view>
      <view class="demon-types">
        <view class="demon-type fear {{selectedDemonType === 'fear' ? 'selected' : ''}}" wx:if="{{showFearOption}}" bindtap="onSelectDemonType" data-type="fear">恐惧</view>
        <view class="demon-type regret {{selectedDemonType === 'regret' ? 'selected' : ''}}" wx:if="{{showRegretOption}}" bindtap="onSelectDemonType" data-type="regret">后悔</view>
      </view>
      <view class="demon-popup-actions">
        <view class="action-button cancel" bindtap="onCloseDemonPopup">
          <image class="button-bg" src="/images/button-bg-cancel.png" />
          <text class="button-text">取消</text>
        </view>
        <view class="action-button confirm" bindtap="onStartDemon">
          <image class="button-bg" src="/images/button-bg-confirm.png" />
          <text class="button-text">开始</text>
        </view>
      </view>
    </view>
  </view>
</view>

<!-- 未配置功法弹窗 -->
<view class="demon-popup-mask" wx:if="{{showNoGongfaPopup}}" bindtap="onCloseNoGongfaPopup">
  <view class="dialog-container" catchtap="preventTouchMove">
    <image class="dialog-bg" src="/images/dialog-bg.png" mode="stretchFix" />
    <view class="dialog-content">
      <view class="demon-popup-title">选择修炼的心魔</view>
      <view class="demon-popup-hint">
        你还没有设置心魔修炼功法，请
        <text class="link-text" catchtap="onGoGongfa">前往心修功法阁</text>
        添加
      </view>
      <view class="demon-popup-actions">
        <view class="action-button cancel" bindtap="onCloseNoGongfaPopup">
          <image class="button-bg" src="/images/button-bg-cancel.png" />
          <text class="button-text">取消</text>
        </view>
        <view class="action-button confirm" bindtap="onGoGongfa">
          <image class="button-bg" src="/images/button-bg-confirm.png" />
          <text class="button-text">开始</text>
        </view>
      </view>
    </view>
  </view>
</view>

<!-- 完成修炼确认弹窗 -->
<view class="demon-popup-mask" wx:if="{{showCompleteConfirmPopup}}" bindtap="onCloseCompleteConfirmPopup">
  <view class="dialog-container" catchtap="preventTouchMove">
    <image class="dialog-bg" src="/images/dialog-bg.png" mode="stretchFix" />
    <view class="dialog-content">
      <view class="demon-popup-title">确认完成修炼？</view>
      <view class="demon-popup-actions">
        <view class="action-button cancel" bindtap="onCloseCompleteConfirmPopup">
          <image class="button-bg" src="/images/button-bg-cancel.png" />
          <text class="button-text">取消</text>
        </view>
        <view class="action-button confirm" bindtap="onConfirmComplete">
          <image class="button-bg" src="/images/button-bg-confirm.png" />
          <text class="button-text">确认</text>
        </view>
      </view>
    </view>
  </view>
</view>

<!-- 修炼结算弹窗 -->
<practice-result
  show="{{showSettlement}}"
  exp="{{settlementInfo.exp}}"
  categoryName="{{settlementInfo.categoryName}}"
  attrChanges="{{settlementInfo.attrChanges}}"
  bind:close="onCloseSettlement"
/>

<!-- 升级/突破弹窗 -->
<level-up-modal
  show="{{showLevelUp}}"
  oldLevel="{{levelUpInfo.oldLevel}}"
  newLevel="{{levelUpInfo.newLevel}}"
  bind:close="onCloseLevelUp"
/>

<!-- 3. 底部输入区 -->
<view class="footer-wrapper" style="padding-bottom: {{keyboardHeight > 0 ? keyboardHeight : (isIphoneX ? 34 : 60)}}px;">
  <view class="footer-input-box">
    <input 
      class="input-field font-system"
      value="{{inputText}}" 
      placeholder="与器灵神识传音..." 
      placeholder-class="input-placeholder"
      confirm-type="send"
      confirm-hold="{{true}}"
      adjust-position="{{false}}"
      focus="{{isFocus}}"
      bindfocus="onInputFocus" 
      bindblur="onInputBlur"
      bindconfirm="sendMessage"
      bindinput="onInputChange"
    />
    <view class="send-icon" bindtap="sendMessage">
      <van-icon name="guide-o" size="26px" color="{{inputText ? '#c0a36a' : '#ccc'}}" />
    </view>
  </view>
</view>

</view>