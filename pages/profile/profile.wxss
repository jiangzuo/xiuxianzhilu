/* pages/profile/profile.wxss (最终 Flexbox 稳定修复版) */

/* --- 1. 页面级样式 --- */
page {
  height: 100vh;
  overflow: hidden;
  color: #3a3a3a;
  background-color: #ECE9DD;
  font-family: sans-serif;
}

/* --- 2. 页面总容器 --- */
.page-wrapper {
  height: 100%;
  display: flex;
  flex-direction: column;
  box-sizing: border-box;
  padding-bottom: calc(50px + env(safe-area-inset-bottom));
}

/* --- 3. 头部容器 --- */
.header-container {
  flex-shrink: 0;
  background-color: #ECE9DD;
  z-index: 10;
  padding-bottom: 20rpx;
}

/* --- 4. 滚动容器 --- */
.scroll-container {
  flex-shrink: 0;
  overflow-y: auto;
  -webkit-overflow-scrolling: touch;
  padding: 0 32rpx;
}

.container {
  width: 100%;
  box-sizing: border-box;
}

/* 导入导出图标样式 */
.import-export-icon {
  width: 40rpx;
  height: 40rpx;
  vertical-align: middle;
}

/* 【核心修复】自定义导航栏布局 */
.custom-nav {
  height: 36px;
  width: 100%;
  position: relative; /* 作为坐标系基准 */
  display: flex;
  align-items: center;
  /* 移除 justify-content，改用绝对定位 */
}

/* 左侧按钮容器 */
.nav-left-container {
  position: absolute;
  left: 16rpx;  /* 紧贴父容器左侧 */
  top: 0;
  height: 100%;
  display: flex;
  align-items: center;
  gap: 20rpx;
  z-index: 20; /* 确保层级高，可点击 */
}

/* 左侧图标：强制绝对定位在最左侧 */
.nav-left {
  height: 100%;
  width: auto;
  display: flex;
  align-items: center;
  justify-content: flex-start; /* 图标靠左对齐 */
  padding: 0 10rpx;
}

.nav-left-text {
  font-size: 24rpx;
  color: #3a3a3a;
  font-weight: 500;
}

/* 2. 中间标题：强制绝对定位在正中心 */
.nav-title {
  position: absolute;
  left: 50%;
  transform: translateX(-50%); /* 经典的绝对居中写法 */
  font-size: 36rpx;
  font-weight: 500;
  color: #3a3a3a;
  z-index: 10;
  white-space: nowrap; /* 防止标题换行 */
  top: 50%;
  transform: translate(-50%, -50%); /* 垂直居中 */
}

/* 右侧占位可以删掉或者留着，因为用了绝对定位，它已经不影响布局了 */
.nav-right-placeholder {
  display: none; 
}


/* --- 面板通用样式 --- */
.panel {
  box-sizing: border-box;
  margin-bottom: 24rpx;
  position: relative; /* 【关键】为内部绝对定位的背景图提供容器 */
  overflow: hidden; /* 防止背景图溢出 */
}

/* 【修复】背景图的通用样式 */
.panel-bg-img {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 1; /* 置于底层 */
}

/* 【修复】面板内容的容器，确保在背景图之上 */
.panel-content {
  position: relative;
  z-index: 2;
  width: 100%;
  height: 100%;
  box-sizing: border-box;
}

/* --- 境界与修为面板 --- */
.realm-panel {
  margin-top: 12rpx;
  height: 140rpx;
}
.realm-panel .panel-content {
  display: flex; 
  flex-direction: column; 
  justify-content: center; 
  align-items: center;
  padding: 10rpx 70rpx 10rpx 80rpx;
}
.realm-name { 
  font-size: 36rpx; 
  font-weight: bold; 
  margin-bottom: 12rpx; 
}
.exp-bar-wrapper { 
  width: 100%; 
  display: flex; 
  align-items: center; 
  font-size: 28rpx; 
}
.exp-label { 
  margin-right: 16rpx; 
}
.progress-bar-container {
  flex: 1;
  height: 48rpx;
  padding: 8rpx 12rpx; 
  box-sizing: border-box;
  position: relative; /* 【关键】为内部元素定位提供容器 */
  border-radius: 999px 0 0 999px; 
  overflow: hidden;
}
.progress-bar-portion {
  /* 【核心修改 ①】将高度从 100% 改为一个具体的值，例如 24rpx */
  /* 你可以根据喜好调整这个数值大小 */
  height: 36rpx;

  /* 【核心修改 ②】将 top 从 0 改为 50% */
  top: 50%;
  transform: translateY(-50%);
  left: 0.1; /* 依然从左侧开始 */
  border-radius: 6px 0 0 6px; /* 可以适当减小圆角，比如 2px，使其更匹配新的高度 */
  transition: width 0.3s ease-in-out;
  z-index: 3;
  background: linear-gradient(to right, #252525, #c0c0c0);
  position: absolute;
}

.exp-value-inside {
  position: absolute;
  right: 24rpx;
  top: 50%;
  transform: translateY(-50%);
  z-index: 4; /* 最高层 */
  font-size: 22rpx;
  color: #3a3a3a;
  text-shadow: 0 0 4rpx rgba(0, 0, 0, 0.5); 
}

/* --- 五大属性面板 --- */
.attributes-panel {
  height: 140rpx;
}
.attributes-panel .panel-content {
  display: flex; 
  flex-direction: column; 
  justify-content: center;
  padding: 10rpx 70rpx 10rpx 80rpx;
  font-size: 28rpx;
}
.attr-row { 
  display: flex; 
  width: 100%; 
  margin-bottom: 12rpx;
}
.attr-row:last-child {
  margin-bottom: 0;
}
.attr-item { 
  width: 33.33%; 
  display: flex; 
  flex-shrink: 0; 
}
.attr-label {
  flex-shrink: 0; 
  margin-right: 6rpx;
}
.attr-value {
  flex-grow: 1; 
  font-weight: 500;
}

/* --- 每日语录面板 --- */
.quote-panel {
  width: 97%; 
  margin-left: auto;
  margin-right: auto;
  min-height: 80rpx; 
  display: flex;
  align-items: center;
}
.quote-panel-bg { /* 此处 image 标签的样式本身就是正确的，无需修改 */
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 1;
}
.quote-content-wrapper {
  position: relative;
  z-index: 2;
  width: 100%;
  padding: 16rpx 48rpx;
  box-sizing: border-box;
  display: flex;
  align-items: center;
}
.quote-icon { 
  width: 32rpx; 
  height: 32rpx; 
  flex-shrink: 0;
  margin-right: 24rpx;
}
.quote-text {
  font-size: 28rpx;
}

/* --- 4. 中间滚动区 --- */
.middle-section {
  flex-shrink: 0;
  overflow-y: auto;
  -webkit-overflow-scrolling: touch;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 20rpx 0;
}
.avatar-image {
  width: 700rpx;
  height: 500rpx;
  display: block;
}

/* --- 5. 底部固定区 --- */
.bottom-section {
  flex-shrink: 0;
  display: flex;
  justify-content: space-around;
  padding: 8rpx 48rpx;
  z-index: 10;
  background: linear-gradient(to top, #ECE9DD, rgba(236, 233, 221, 0));
}
.action-button {
  width: 280rpx; 
  height: 120rpx;
  display: flex; 
  justify-content: center; 
  align-items: center;
  font-size: 32rpx; 
  font-weight: 500;
  position: relative; /* 【关键】为背景图和文字提供定位容器 */
  overflow: hidden; /* 防止背景图溢出 */
}
/* 【修复】按钮文字样式 */
.btn-text {
  position: relative;
  z-index: 2; /* 确保文字在背景图之上 */
}

/* === 玩法说明弹窗样式优化 === */
/* =========================== */

.help-container {
  width: 600rpx;
  position: relative;
  /* 移除底部的 padding-bottom，因为控制栏悬浮了 */
  border-radius: 24rpx;
  overflow: hidden; 
  /* 背景透明，因为图片已经撑满了 */
  background-color: transparent; 
}

/* 关闭按钮区域 (保持悬浮) */
.help-close-area {
  position: absolute;
  top: 20rpx;
  right: 20rpx;
  width: 60rpx;
  height: 60rpx;
  z-index: 20; /* 确保在最上层 */
  display: flex;
  justify-content: center;
  align-items: center;
}

.help-close-img {
  width: 60rpx; /* 稍微调小一点精致些 */
  height: 60rpx;
  opacity: 0.6;
}

/* 轮播图容器 */
.help-swiper {
  width: 100%;
  /* 高度依然需要指定，根据你的图片比例设定，例如 3:4 */
  height: 900rpx; 
  background-color: #ECE9DD;
}

.help-image {
  width: 100%;
  height: 100%;
  display: block;
}

/* --- 【核心修改】悬浮底部控制栏 --- */
.help-controls-overlay {
  position: absolute; /* 绝对定位 */
  bottom: 40rpx;      /* 距离底部的位置 */
  left: 0;
  width: 100%;
  display: flex;
  justify-content: center; /* 整体居中 */
  align-items: center;
  gap: 60rpx; /* 按钮和页码之间的间距 */
  z-index: 20; /* 浮在图片上面 */
}

/* 圆形按钮容器 */
.control-btn {
  width: 70rpx;
  height: 70rpx;
  border-radius: 50%;
  /* 半透明白底，制造磨砂感，防止背景干扰 */
  background-color: rgba(187, 211, 171, 0.596);
  display: flex;
  justify-content: center;
  align-items: center;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.1);
  transition: all 0.2s;
}

.control-btn:active {
  transform: scale(0.9);
  background-color: rgba(255, 255, 255, 0.95);
}

/* 禁用状态 */
.control-btn.disabled {
  opacity: 0; /* 第一页/最后一页时直接隐藏按钮，视觉更干净 */
  pointer-events: none;
}

/* 页码数字 */
.page-indicator {
  font-size: 28rpx;
  /* 颜色深一点，确保在浅绿色背景上可见 */
  color: #5c5241; 
  font-weight: 500;
  font-family: sans-serif;
  letter-spacing: 4rpx;
}

/* === 器灵悬浮入口样式 === */
/* =========================== */

.spirit-float-btn {
  position: fixed;
  right: 30rpx;
  /* 距离底部的高度，避开 TabBar 和底部的“感悟日记”按钮 */
  bottom: 440rpx; 
  width: 200rpx;
  height: 200rpx;
  z-index: 100;
  
  /* 添加上下浮动动画 */
  animation: floatSpirit 3s ease-in-out infinite;
}

.spirit-img {
  width: 100%;
  height: 100%;
  /* 给个发光效果，更有灵性 */
  filter: drop-shadow(0 0 10rpx rgba(192, 163, 106, 0.6));
}


/* 浮动动画关键帧 */
@keyframes floatSpirit {
  0% { transform: translateY(0px); }
  50% { transform: translateY(-10px); } /* 上浮 10px */
  100% { transform: translateY(0px); }
}

/* === 导入导出样式 === */
/* ===================== */

/* 导入导出选择弹窗 */
.import-export-container {
  width: 500rpx;
  background-color: #ECE9DD;
  border-radius: 24rpx;
  padding: 32rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.15);
}

.import-export-header {
  text-align: center;
  margin-bottom: 32rpx;
}

.import-export-title {
  font-size: 36rpx;
  font-weight: 500;
  color: #3a3a3a;
}

.import-export-content {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.import-export-button {
  height: 96rpx;
  background-color: #f5f5f5;
  border-radius: 16rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  transition: all 0.2s;
}

.import-export-button:active {
  background-color: #e0e0e0;
  transform: scale(0.98);
}

.import-export-button-text {
  font-size: 32rpx;
  color: #3a3a3a;
}

/* 导入数据弹窗 */
.import-container {
  width: 600rpx;
  background-color: #ECE9DD;
  border-radius: 24rpx;
  padding: 32rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.15);
}

.import-header {
  text-align: center;
  margin-bottom: 24rpx;
}

.import-title {
  font-size: 36rpx;
  font-weight: 500;
  color: #3a3a3a;
}

.import-content {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.import-desc {
  font-size: 24rpx;
  color: #666;
  line-height: 1.5;
}

.import-textarea {
  width: 100%;
  max-height: 500rpx;
  background-color: #f5f5f5;
  border-radius: 16rpx;
  padding: 20rpx;
  font-size: 24rpx;
  line-height: 1.5;
  box-sizing: border-box;
  resize: none;
  overflow-y: auto;
  white-space: pre-wrap;
  word-wrap: break-word;
}

.import-actions {
  display: flex;
  justify-content: space-around;
  gap: 32rpx;
  margin-top: 16rpx;
}

.import-action-button {
  width: 240rpx;
  height: 80rpx;
  position: relative;
  display: flex;
  justify-content: center;
  align-items: center;
}

.import-action-button .button-bg {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 1;
}

.import-action-button .button-text {
  position: relative;
  z-index: 2;
  font-size: 28rpx;
  font-weight: 500;
  color: #ffffff;
}

/* === 器灵话语样式 === */
.spirit-message {
  position: fixed;
  right: 180rpx;
  bottom: 520rpx;
  max-width: 360rpx;
  padding: 16rpx 24rpx;
  background: linear-gradient(135deg, #f5f5f5 0%, #e8e8e8 100%);
  border-radius: 16rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.15);
  z-index: 99;
  opacity: 0;
  transform: translateX(20rpx);
  transition: all 0.3s ease;
}

.spirit-message.show {
  opacity: 1;
  transform: translateX(0);
}

.spirit-message::after {
  content: '';
  position: absolute;
  right: -16rpx;
  top: 50%;
  transform: translateY(-50%);
  border: 8rpx solid transparent;
  border-left-color: #e8e8e8;
}

.spirit-message-text {
  font-size: 26rpx;
  color: #3a3a3a;
  line-height: 1.5;
  word-break: break-all;
}

