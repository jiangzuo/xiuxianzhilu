/* pkg_review/pages/review/review.wxss */

/* --- 1. 页面级样式 --- */
page {
  height: 100%;
  overflow: hidden;
  background-color: #eae8dc;
  font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', Helvetica, Segoe UI, Arial, Roboto, 'PingFang SC', 'Hiragino Sans GB', 'Microsoft Yahei', sans-serif;
}

/* 覆盖全局隶书字体 */
text {
  font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', Helvetica, Segoe UI, Arial, Roboto, 'PingFang SC', 'Hiragino Sans GB', 'Microsoft Yahei', sans-serif !important;
}

/* --- 2. 页面总容器：Flex 布局 --- */
.page-container {
  height: 100%;
  display: flex;
  flex-direction: column;
  position: relative;
}

/* 背景图样式 */
.review-bg {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 0;
}

/* --- 3. 顶部固定区 --- */
.custom-nav {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 44px;
  padding: 0 32rpx;
  flex-shrink: 0;
  background-color: transparent;
  position: relative;
  z-index: 10;
}

.nav-left, .nav-right {
  width: 40rpx;
  display: flex;
  align-items: center;
}

.nav-center {
  flex: 1;
  text-align: center;
  font-size: 34rpx;
  font-weight: 500;
  color: #5c5241;
  font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', Helvetica, Segoe UI, Arial, Roboto, 'PingFang SC', 'Hiragino Sans GB', 'Microsoft Yahei', sans-serif;
}

.back-icon {
  font-size: 40rpx;
  color: #5c5241;
  font-weight: bold;
}

/* --- 4. 中间滚动区 --- */
.scroll-container {
  flex: 1;
  overflow-y: auto;
  -webkit-overflow-scrolling: touch;
  padding: 32rpx;
  box-sizing: border-box;
  position: relative;
  z-index: 5;
}

/* 空状态 */
.empty-state {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 200px;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
  font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', Helvetica, Segoe UI, Arial, Roboto, 'PingFang SC', 'Hiragino Sans GB', 'Microsoft Yahei', sans-serif;
}

/* 记录列表 */
.record-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.record-item {
  padding: 24rpx 32rpx;
  border-radius: 8px;
  background-color: rgba(255, 255, 255, 0.6);
}

.record-item.practice .record-text {
  color: #5c5241;
}

.record-item.levelup .record-text {
  color: #d86c32;
}

.record-item.ai-review .record-text {
  color: #5a7d9a;
}

.record-text {
  font-size: 28rpx;
  line-height: 1.6;
  font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', Helvetica, Segoe UI, Arial, Roboto, 'PingFang SC', 'Hiragino Sans GB', 'Microsoft Yahei', sans-serif;
}

/* 加载更多 */
.loading-more {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx 0;
}

.loading-text {
  font-size: 24rpx;
  color: #999;
  font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', Helvetica, Segoe UI, Arial, Roboto, 'PingFang SC', 'Hiragino Sans GB', 'Microsoft Yahei', sans-serif;
}

/* 没有更多 */
.no-more {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx 0;
}

.no-more-text {
  font-size: 24rpx;
  color: #bbb;
  font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', Helvetica, Segoe UI, Arial, Roboto, 'PingFang SC', 'Hiragino Sans GB', 'Microsoft Yahei', sans-serif;
}
